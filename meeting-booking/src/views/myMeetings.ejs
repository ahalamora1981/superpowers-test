<%- include('partials/header') %>
<div class="main-wrap">
  <h1 class="page-title">My meetings</h1>

  <h2>Upcoming</h2>
  <% if (upcoming.length === 0) { %>
    <div class="card empty">
      <p>No upcoming meetings.</p>
      <a href="/meetings/new" class="btn btn-primary">Schedule one →</a>
    </div>
  <% } else { %>
    <div class="card">
      <ul class="meeting-list">
        <% upcoming.forEach(function(m) { %>
          <li>
            <a href="/meetings/<%= m.id %>" class="meeting-title"><%= m.title %></a>
            <span class="meeting-time"><%= m.start_utc %></span>
            <span class="badge badge-scheduled"><%= m.timezone %></span>
          </li>
        <% }); %>
      </ul>
    </div>
  <% } %>

  <h2>Past / Cancelled</h2>
  <% if (past.length === 0) { %>
    <p class="text-muted">None.</p>
  <% } else { %>
    <div class="card">
      <ul class="meeting-list">
        <% past.forEach(function(m) { %>
          <li>
            <a href="/meetings/<%= m.id %>" class="meeting-title"><%= m.title %></a>
            <span class="meeting-time"><%= m.start_utc %></span>
            <span class="badge <%= m.status === 'cancelled' ? 'badge-cancelled' : 'badge-scheduled' %>"><%= m.status %></span>
          </li>
        <% }); %>
      </ul>
    </div>
  <% } %>
</div>
<%- include('partials/footer') %>
