<%- include('../partials/header') %>
<div class="main-wrap">
  <div class="flex-between mb-lg">
    <h1 class="page-title" style="margin-bottom:0"><%= meeting.title %></h1>
    <% if (canModify && meeting.status === 'scheduled') { %>
    <div class="flex gap-sm">
      <a href="/meetings/<%= meeting.id %>/edit" class="btn btn-secondary btn-sm">Edit</a>
      <form method="POST" action="/meetings/<%= meeting.id %>/cancel" style="display:inline" onsubmit="return confirm('Cancel this meeting and notify all attendees?')">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-danger btn-sm">Cancel</button>
      </form>
    </div>
    <% } %>
  </div>

  <% if (flash) { %><div class="alert alert-warning"><%= flash %></div><% } %>
  <% if (meeting.status === 'cancelled') { %><div class="alert alert-error">This meeting has been cancelled.</div><% } %>

  <div class="card-row">
    <div class="card">
      <h3 style="margin-top:0">Details</h3>
      <div class="meeting-meta">
        <div class="meeting-meta-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          <%= meeting.start_utc %> – <%= meeting.end_utc %>
        </div>
        <div class="meeting-meta-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          <%= meeting.timezone %>
        </div>
      </div>
      <% if (meeting.description) { %>
        <p class="text-muted"><%= meeting.description %></p>
      <% } %>
    </div>

    <div class="card">
      <h3 style="margin-top:0">Organizer</h3>
      <p><strong><%= organizer.display_name %></strong></p>
      <p class="text-muted"><%= organizer.email %></p>
      <hr class="divider">
      <a href="<%= meeting.join_url %>" class="btn btn-primary" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px"><polygon points="5 3 19 12 5 21"/></svg>
        Join meeting
      </a>
    </div>
  </div>

  <div class="card">
    <h3 style="margin-top:0">Attendees</h3>
    <% if (parts.length === 0) { %>
      <p class="text-muted">No attendees yet.</p>
    <% } else { %>
      <ul class="attendee-list">
        <% parts.forEach(function(p) { %>
          <li>
            <strong><%= p.name || p.email %></strong>
            <% if (p.name) { %><span class="text-muted">&lt;<%= p.email %>&gt;</span><% } %>
          </li>
        <% }); %>
      </ul>
    <% } %>
  </div>

  <p><a href="/">← Back to calendar</a></p>
</div>
<%- include('../partials/footer') %>
