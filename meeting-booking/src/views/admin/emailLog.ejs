<%- include('../partials/header') %>
<div class="main-wrap">
  <h1 class="page-title">Email log</h1>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>When</th>
          <th>Kind</th>
          <th>Recipient</th>
          <th>Status</th>
          <th>Error</th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach(function(r) { %>
          <tr>
            <td><%= r.sent_at %></td>
            <td><%= r.kind %></td>
            <td><%= r.recipient %></td>
            <td><span class="badge <%= r.status === 'sent' ? 'badge-sent' : 'badge-failed' %>"><%= r.status %></span></td>
            <td class="text-muted"><%= r.error || '—' %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <% if (rows.length === 0) { %>
    <div class="empty">
      <p>No emails sent yet.</p>
    </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
